{
  "name": "@d1dx/n8n-nodes-instant-airtable-trigger",
  "version": "1.1.0",
  "description": "N8N node for Airtable instant webhook triggers with view filtering. Forked from vwork Digital, enhanced by D1DX.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "airtable",
    "webhook",
    "trigger",
    "instant",
    "real-time"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://github.com/D1DX/n8n-nodes-instant-airtable-trigger",
  "author": {
    "name": "D1DX",
    "url": "https://d1dx.com"
  },
  "contributors": [
    {
      "name": "Jacob Vendramin",
      "email": "jacob@vwork.digital",
      "url": "https://vwork.digital"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/D1DX/n8n-nodes-instant-airtable-trigger.git"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "echo 'Publishing pre-built dist/'"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AirtableApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AirtableTrigger/AirtableTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}